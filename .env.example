# =========================================================================
# @leovelabot — Variables de Entorno
# =========================================================================
# Copia este archivo como .env y rellena con tus claves reales.
# En Render.com, configúralas en el panel de Environment Variables.

# --- TELEGRAM (Obligatorio) ---
# Obtener de @BotFather en Telegram → /mytoken
TELEGRAM_BOT_TOKEN=tu_token_de_botfather

# --- GEMINI AI (Obligatorio, Gratis) ---
# Obtener de https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_de_google_ai_studio

# --- ADMIN (Recomendado) ---
# Tu chat ID personal → habla con @userinfobot en Telegram
ADMIN_CHAT_ID=tu_chat_id

# --- WHATSAPP (Opcional — activar para modo dual) ---
# Obtener de Meta for Developers → WhatsApp Cloud API
WHATSAPP_TOKEN=tu_token_de_meta
WHATSAPP_PHONE_ID=tu_phone_number_id
WA_VERIFY_TOKEN=c8l_leovela_2026
ADMIN_PHONE=34611636294

# --- SERVIDOR (No tocar — Render los gestiona) ---
PORT=8080
TEMP_DIR=/tmp/leovelabot_videos
