# =========================================================================
# @leovelabot — Variables de Entorno (HOSTING EN LA NUBE)
# =========================================================================
# Copia este archivo como .env y rellena con tus claves reales.
# Estas claves se configuran en Render.com → Environment Variables.

# --- TELEGRAM (Obligatorio) ---
# Obtener de @BotFather en Telegram → /newbot o /mytoken
TELEGRAM_BOT_TOKEN=tu_token_de_botfather

# --- GEMINI AI (Obligatorio, Gratis) ---
# Obtener de https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_de_google_ai_studio

# --- HUGGING FACE (Recomendado, Gratis) ---
# Obtener de https://huggingface.co/settings/tokens
# Se usa para generar imágenes con Stable Diffusion y vídeos con modelos open source
HUGGINGFACE_TOKEN=tu_token_de_huggingface

# --- WHATSAPP CLOUD API (Obligatorio para WhatsApp) ---
# Obtener de https://developers.facebook.com → Tu App → WhatsApp → API Setup
WHATSAPP_TOKEN=tu_token_permanente_de_meta
WHATSAPP_PHONE_ID=tu_phone_number_id

# --- WEBHOOK (WhatsApp) ---
# Token de verificación que TÚ defines (cualquier string seguro)
WA_VERIFY_TOKEN=c8l_leovela_2026

# --- ADMIN (Recomendado) ---
# Tu chat ID personal → habla con @userinfobot en Telegram
ADMIN_CHAT_ID=tu_chat_id
# Tu número de WhatsApp con código de país (sin + ni espacios)
ADMIN_PHONE=34611636294

# --- SERVIDOR (No tocar en Render — Render asigna PORT automáticamente) ---
PORT=10000
HEALTH_PORT=8080
TEMP_DIR=/tmp/leovelabot_videos

# --- BASE DE DATOS (Memoria persistente) ---
# Ruta al archivo SQLite de la memoria del bot
DATABASE_PATH=/app/agents/memory_data/hermes_memory.db
